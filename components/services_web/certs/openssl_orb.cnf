[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
CN = orb-s3.local

[v3_req]
keyUsage = keyEncipherment, digitalSignature
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = orb-s3.local
DNS.2 = localhost
IP.1 = 127.0.0.1
IP.2 = 192.168.4.1
IP.3 = 192.168.43.242
