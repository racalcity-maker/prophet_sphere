menu "Config Configuration"

config ORB_CONFIG_PERSIST_TO_NVS
    bool "Persist runtime config to NVS"
    default y

config ORB_CONFIG_NVS_NAMESPACE
    string "NVS namespace for runtime config"
    default "orb_cfg"
    depends on ORB_CONFIG_PERSIST_TO_NVS

menu "Offline Runtime Defaults"

choice ORB_CFG_DEFAULT_OFFLINE_SUBMODE
    prompt "Default offline submode"
    default ORB_CFG_DEFAULT_OFFLINE_SUBMODE_AURA

config ORB_CFG_DEFAULT_OFFLINE_SUBMODE_AURA
    bool "aura"

config ORB_CFG_DEFAULT_OFFLINE_SUBMODE_LOTTERY
    bool "lottery"

config ORB_CFG_DEFAULT_OFFLINE_SUBMODE_PROPHECY
    bool "prophecy"
endchoice

config ORB_CFG_DEFAULT_AURA_INTRO_DIR
    string "Aura intro tracks folder"
    default "/sdcard/audio/aura/intro"

config ORB_CFG_DEFAULT_AURA_RESPONSE_DIR
    string "Aura response tracks folder"
    default "/sdcard/audio/aura/response"

config ORB_CFG_DEFAULT_AURA_GAP_MS
    int "Aura gap between intro and response (ms)"
    range 0 30000
    default ORB_AURA_TRACK_GAP_MS

endmenu

endmenu
