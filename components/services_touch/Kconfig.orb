menu "Touch Configuration"

config ORB_TOUCH_ENABLE_REAL
    bool "Enable real capacitive touch service"
    default y

config ORB_TOUCH_ZONE0_CHANNEL
    int "Touch zone 0 channel"
    range 1 1
    default 1
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_ZONE1_CHANNEL
    int "Touch zone 1 channel"
    range 2 2
    default 2
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_ZONE2_CHANNEL
    int "Touch zone 2 channel"
    range 3 3
    default 3
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_ZONE3_CHANNEL
    int "Touch zone 3 channel"
    range 4 4
    default 4
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_POLL_PERIOD_MS
    int "Touch poll period (ms)"
    range 5 200
    default 8
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_STOP_TIMEOUT_MS
    int "Touch task stop timeout (ms)"
    range 100 10000
    default 1200

config ORB_TOUCH_CALIBRATION_SAMPLES
    int "Touch startup calibration samples"
    range 8 200
    default 24
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_DEBOUNCE_COUNT
    int "Touch debounce count"
    range 1 20
    default 2
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_RELEASE_DEBOUNCE_COUNT
    int "Touch release debounce count"
    range 1 20
    default 2
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_STUCK_PRESS_TIMEOUT_MS
    int "Touch stuck press timeout (ms)"
    range 0 30000
    default 0
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_HOLD_EVENT_ENABLE
    bool "Enable touch hold event"
    default y
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_HOLD_TIME_MS
    int "Touch hold time (ms)"
    range 100 10000
    default 5000
    depends on ORB_TOUCH_HOLD_EVENT_ENABLE

config ORB_TOUCH_THRESHOLD_PERCENT
    int "Touch threshold percent of baseline"
    range 1 50
    default 3
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_THRESHOLD_MIN_DELTA
    int "Touch minimum threshold delta"
    range 10 5000
    default 60
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_RELEASE_THRESHOLD_PERCENT
    int "Release threshold (% of touch threshold)"
    range 10 95
    default 45
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_FILTER_SMOOTH_SHIFT
    int "Raw filter smoothing shift"
    range 1 8
    default 1
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_BASELINE_SMOOTH_SHIFT
    int "Baseline smoothing shift"
    range 2 10
    default 6
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_DIAG_LOG_ENABLE
    bool "Enable touch diagnostic logs"
    default n
    depends on ORB_TOUCH_ENABLE_REAL

config ORB_TOUCH_DIAG_LOG_PERIOD_MS
    int "Touch diagnostic log period (ms)"
    range 500 60000
    default 2000
    depends on ORB_TOUCH_DIAG_LOG_ENABLE

endmenu
