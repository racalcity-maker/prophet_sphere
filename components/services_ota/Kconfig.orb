menu "OTA Configuration"

config ORB_ENABLE_OTA
    bool "Enable OTA service"
    default n
    depends on ORB_ENABLE_NETWORK

config ORB_OTA_ALLOW_HTTP
    bool "Allow HTTP OTA URL (unsafe, for local testing only)"
    default n
    depends on ORB_ENABLE_OTA

config ORB_OTA_URL_MAX_LEN
    int "Maximum OTA URL length"
    range 64 512
    default 192
    depends on ORB_ENABLE_OTA

endmenu
