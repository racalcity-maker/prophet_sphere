menu "Board Configuration"

config ORB_DEVICE_NAME
    string "Device name"
    default "orb-s3"

config ORB_BOARD_LED_GPIO
    int "Board LED GPIO"
    default 2

config ORB_STATUS_GPIO
    int "Status/Service GPIO"
    default 4

config ORB_LED_DATA_GPIO
    int "LED data GPIO"
    default 48

config ORB_AMP_ENABLE_GPIO
    int "Amplifier enable GPIO"
    default 21

menu "Mode Button Configuration"

config ORB_MODE_BUTTON_ENABLE
    bool "Enable hardware mode button (active-low to GND)"
    default y

config ORB_MODE_BUTTON_GPIO
    int "Mode button GPIO"
    range 0 48
    default 14
    depends on ORB_MODE_BUTTON_ENABLE

config ORB_MODE_BUTTON_PULLUP_ENABLE
    bool "Enable internal pull-up"
    default y
    depends on ORB_MODE_BUTTON_ENABLE

config ORB_MODE_BUTTON_POLL_MS
    int "Button poll period (ms)"
    range 1 100
    default 10
    depends on ORB_MODE_BUTTON_ENABLE

config ORB_MODE_BUTTON_DEBOUNCE_MS
    int "Button debounce (ms)"
    range 5 200
    default 20
    depends on ORB_MODE_BUTTON_ENABLE

config ORB_MODE_BUTTON_TASK_STACK_SIZE
    int "Mode button task stack size"
    range 1536 4096
    default 3072
    depends on ORB_MODE_BUTTON_ENABLE

config ORB_MODE_BUTTON_TASK_PRIORITY
    int "Mode button task priority"
    range 1 24
    default 5
    depends on ORB_MODE_BUTTON_ENABLE

endmenu

menu "Submode Button Configuration"

config ORB_SUBMODE_BUTTON_ENABLE
    bool "Enable hardware submode button (active-low to GND)"
    default y

config ORB_SUBMODE_BUTTON_GPIO
    int "Submode button GPIO"
    range 0 48
    default 15
    depends on ORB_SUBMODE_BUTTON_ENABLE

config ORB_SUBMODE_BUTTON_PULLUP_ENABLE
    bool "Enable internal pull-up"
    default y
    depends on ORB_SUBMODE_BUTTON_ENABLE

config ORB_SUBMODE_BUTTON_POLL_MS
    int "Submode button poll period (ms)"
    range 1 100
    default 10
    depends on ORB_SUBMODE_BUTTON_ENABLE

config ORB_SUBMODE_BUTTON_DEBOUNCE_MS
    int "Submode button debounce (ms)"
    range 5 200
    default 25
    depends on ORB_SUBMODE_BUTTON_ENABLE

config ORB_SUBMODE_BUTTON_TASK_STACK_SIZE
    int "Submode button task stack size"
    range 1536 4096
    default 3072
    depends on ORB_SUBMODE_BUTTON_ENABLE

config ORB_SUBMODE_BUTTON_TASK_PRIORITY
    int "Submode button task priority"
    range 1 24
    default 5
    depends on ORB_SUBMODE_BUTTON_ENABLE

endmenu

endmenu
