menu "Network Configuration"

config ORB_ENABLE_NETWORK
    bool "Enable network service"
    default y

choice ORB_NETWORK_MODE_POLICY_OFFLINE
    prompt "Offline Mode Network Policy"
    default ORB_NETWORK_OFFLINE_USE_SOFTAP
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_OFFLINE_USE_NONE
    bool "No Wi-Fi in offline mode"

config ORB_NETWORK_OFFLINE_USE_SOFTAP
    bool "Local SoftAP only (no external network)"
endchoice

choice ORB_NETWORK_MODE_POLICY_HYBRID
    prompt "Hybrid AI Mode Network Policy"
    default ORB_NETWORK_HYBRID_USE_STA
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_HYBRID_USE_NONE
    bool "No Wi-Fi in hybrid mode"

config ORB_NETWORK_HYBRID_USE_STA
    bool "STA client (connect to router)"
endchoice

choice ORB_NETWORK_MODE_POLICY_INSTALLATION
    prompt "Installation Mode Network Policy"
    default ORB_NETWORK_INSTALLATION_USE_STA
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_INSTALLATION_USE_NONE
    bool "No Wi-Fi in installation mode"

config ORB_NETWORK_INSTALLATION_USE_STA
    bool "STA client (connect to router)"

config ORB_NETWORK_INSTALLATION_USE_SOFTAP
    bool "SoftAP mode"
endchoice

config ORB_NETWORK_HOSTNAME
    string "STA hostname"
    default "orb-s3"
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_DISABLE_WIFI_PS
    bool "Disable Wi-Fi power-save"
    default y
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_STA_CONNECT_TIMEOUT_MS
    int "STA connect timeout (ms)"
    range 1000 120000
    default 15000
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_STA_RETRY_MAX
    int "STA reconnect retries"
    range 0 20
    default 5
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_EVENT_POST_TIMEOUT_MS
    int "App event post timeout from network callbacks (ms)"
    range 1 200
    default 10
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_APSTA_SMART_FROM_NVS
    bool "Smart APSTA startup from NVS STA credentials"
    default y
    depends on ORB_ENABLE_NETWORK
    help
        If enabled and mode policy requests APSTA, network manager first checks
        whether STA credentials were persisted in NVS. If yes, it starts STA-only
        (no setup AP). If no credentials are present in NVS, APSTA is kept so
        provisioning UI can stay available.

menu "STA Configuration"
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_STA_SSID
    string "STA SSID"
    default ""

config ORB_NETWORK_STA_PASSWORD
    string "STA Password"
    default ""

endmenu

menu "SoftAP Configuration"
    depends on ORB_ENABLE_NETWORK

config ORB_NETWORK_AP_SSID
    string "SoftAP SSID"
    default "orb-offline"

config ORB_NETWORK_AP_PASSWORD
    string "SoftAP password (empty => open)"
    default "orbmagic42"

config ORB_NETWORK_AP_CHANNEL
    int "SoftAP channel"
    range 1 13
    default 6

config ORB_NETWORK_AP_MAX_CONNECTIONS
    int "SoftAP max stations"
    range 1 10
    default 4

config ORB_NETWORK_AP_HIDE_SSID
    bool "Hide SoftAP SSID"
    default n

endmenu

endmenu
