# Build/output
/build/
/cmake-build-*/
*.o
*.obj
*.a
*.so
*.dll
*.exe
*.map

# ESP-IDF local/generated
/sdkconfig
/sdkconfig.old
/managed_components/

# Local IDE/system
/.vscode/
.DS_Store
Thumbs.db

# Python cache/venv
**/__pycache__/
**/*.pyc
*.pyc
*.pyo
.venv/
venv/

# Archives/local drops
*.zip
/Oracle.zip

# Runtime/log/temp artifacts
*.log
*.tmp
*.bak
*.swp
*.swo
kws/captures/

# Generated local TLS keys/certs (never commit private keys)
components/services_web/certs/prvtkey.pem
components/services_web/certs/ca_key.pem
components/services_web/certs/servercert.pem
components/services_web/certs/ca_cert.pem
components/services_web/certs/*key*.pem
components/services_web/certs/*.bak

# Audio/text backup artifacts: keep only working text banks
/docs/texts_backup_*/
/docs/texts_broken_*/
/docs/texts/*.bak.txt
/docs/text_improoved/
/docs/texts.zip
